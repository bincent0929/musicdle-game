{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    // This is what's causing everything to go into the dist folder
    "outDir": "./"
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "server"]
}
